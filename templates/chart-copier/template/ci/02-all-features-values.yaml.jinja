# CI test values — all optional features enabled.
# Used by chart-testing (ct) to validate the chart with every feature toggled on.

replicaCount: 2
[% if use_service_account %]
serviceAccount:
  create: true
  annotations:
    eks.amazonaws.com/role-arn: arn:aws:iam::123456789012:role/test
[% endif %]
[% if use_ingress %]
ingress:
  enabled: true
  className: nginx
  hosts:
    - host: test.example.com
      paths:
        - path: /
          pathType: Prefix
[% endif %]
[% if use_hpa %]
autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 5
  targetCPUUtilizationPercentage: 70
[% endif %]
[% if use_pdb %]
pdb:
  enabled: true
  minAvailable: 1
[% endif %]
[% if use_networkpolicy %]
networkPolicy:
  enabled: true
[% endif %]
[% if use_pvc %]
persistence:
  enabled: true
  size: 5Gi
[% endif %]
resources:
  limits:
    cpu: 200m
    memory: 256Mi
  requests:
    cpu: 100m
    memory: 128Mi
